{
  "name": "@exwhyzed/pdflet",
  "version": "1.0.1",
  "description": "Official SDK for the ResumeForge PDF Generation API — generate resumes, check ATS scores, and manage templates.",
  "author": "ResumeForge",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/exwhyzed/pdflet"
  },
  "homepage": "https://github.com/exwhyzed/pdflet#readme",
  "bugs": {
    "url": "https://github.com/exwhyzed/pdflet/issues"
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "pdf",
    "resume",
    "ats",
    "resume-builder",
    "pdf-generator",
    "sdk",
    "api-client"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  }
}
